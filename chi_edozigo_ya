src/strategy/baseline.py
```
import pandas as pd

class SMACrossover:
def __init__(self, short_col='sma_short', long_col='sma_long'):
self.short_col = short_col
self.long_col = long_col

def generate_signals(self, df: pd.DataFrame):
df = df.copy()
# entry when short crosses above long
entries = (df[self.short_col] > df[self.long_col]) & (df[self.short_col].shift(1) <= df[self.long_col].shift(1))
exits = (df[self.short_col] < df[self.long_col]) & (df[self.short_col].shift(1) >= df[self.long_col].shift(1))
entries = entries.astype(bool)
exits = exits.astype(bool)
return entries, exits
```





src/strategy/ml_strategy.py
```
import pandas as pd
from src.ml.predict import predict_signals

class MLSignalStrategy:
def __init__(self, model_path: str, threshold: float = 0.5):
self.model_path = model_path
self.threshold = threshold

def generate_signals(self, feature_df: pd.DataFrame):
signals, probs = predict_signals(self.model_path, feature_df, threshold=self.threshold)
# For vectorbt: entries as boolean Series; exits when signal flips to 0 or after fixed horizon
entries = pd.Series(signals, index=feature_df.index).astype(bool)
exits = (~entries).astype(bool)
return entries, exits, probs
```



src/backtest/backtest.py
```
import vectorbt as vbt
import pandas as pd
from pathlib import Path

def run_vectorbt_backtest(df: pd.DataFrame, entries: pd.Series, exits: pd.Series, results_dir: str, symbol: str):
close = df['close']
pf = vbt.Portfolio.from_signals(close, entries=entries, exits=exits, init_cash=10000, fees=0.0005, slippage=0.0005)
Path(results_dir).mkdir(parents=True, exist_ok=True)
metrics = {
'total_return': float(pf.total_return()),
'sharpe': float(pf.sharpe_ratio()),
'max_drawdown': float(pf.max_drawdown()),
'trades': int(pf.total_trades())
}
with open(f"{results_dir}/{symbol.replace('/','-')}_metrics.txt", 'w') as f:
f.write(str(metrics))
# save equity curve plot
fig = pf.total_return().vbt.plot().figure
fig.savefig(f"{results_dir}/{symbol.replace('/','-')}_equity.png")
return pf, metrics
```

scripts/run_pipeline.py
```
import yaml
import os
from src.data_pipeline.ingest import ingest_to_parquet
from src.features.engineer import load_parquet, add_basic_features, add_ml_labels
from src.strategy.baseline import SMACrossover
from src.strategy.ml_strategy import MLSignalStrategy
from src.backtest.backtest import run_vectorbt_backtest
from src.ml.train import train_model
from src.utils.logging import get_logger

logger = get_logger(__name__)

def main():
cfg = yaml.safe_load(open('config/config.yaml'))
mode = cfg.get('mode', 'paper')
exchange = cfg['exchange']
symbols = cfg.get('symbols', ['BTC/USDT'])
timeframe = cfg.get('timeframe', '1h')
limit = cfg.get('limit', 1000)
results_dir = cfg.get('results_dir', 'results')
model_dir = cfg.get('model_dir', 'models')

os.makedirs(results_dir, exist_ok=True)
os.makedirs(model_dir, exist_ok=True)

for symbol in symbols:
logger.info(f"Ingesting {symbol}")
path = ingest_to_parquet(exchange, symbol, timeframe, limit, cfg['data_dir'])
df = load_parquet(path)
features = add_basic_features(df, sma_short=cfg['sma_short'], sma_long=cfg['sma_long'])
features = add_ml_labels(features, horizon=cfg['ml']['label_horizon'])

# Train ML model (for demo purposes we train here; in production train offline)
model_path, _ = train_model(path, config_path='config/config.yaml')

# Use ML strategy signals
ml_strategy = MLSignalStrategy(model_path)
entries, exits, probs = ml_strategy.generate_signals(features)

# Backtest
pf, metrics = run_vectorbt_backtest(features, entries, exits, results_dir, symbol)
logger.info('Backtest metrics: %s', metrics)

if __name__ == '__main__':
main()
```

